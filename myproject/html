                        <strong>O:</strong> {$row['pemeriksaan']}<br>
                        <strong>A:</strong> {$row['penilaian']}<br>
                        <strong>P:</strong> {$row['rtl']}
                    </td>
                    <td>{$row['instruksi']}</td>
                </tr>";
        }
        echo "</table>";
    } else {
